# Copy to .env (local) or set these in Infomaniak site > Environment variables.
# Never commit the real .env (it is gitignored). Generate a fresh PAYLOAD_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"

# Session-signing secret for Payload (keep private, 40+ chars)
PAYLOAD_SECRET=replace-with-a-long-random-string-40-chars-min

# SQLite database file. Local: relative path is fine.
# Server: use an absolute persistent path, e.g. file:/home/clients/<yourID>/persistent/payload.db
DATABASE_URI=file:./data/payload.db

# Public base URL of the site
NEXT_PUBLIC_SERVER_URL=https://new.acuvstrategy.com

# Absolute directory for uploaded media so it survives redeploys (optional locally).
# Server: e.g. /home/clients/<yourID>/persistent/media
# MEDIA_DIR=/home/clients/<yourID>/persistent/media
